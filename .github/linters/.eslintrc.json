{
  "root": true,
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "es6": true,
    "browser": true
  },
  "parserOptions": {
    "jsx": true,
    "ecmaVersion": 6,
    "sourceType": "module"
  },
  "ignorePatterns": [
    "*.d.ts",
    "vite.config.ts"
  ]
}
